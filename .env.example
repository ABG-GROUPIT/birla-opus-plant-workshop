# Supabase is the authoritative submission store in every environment.
SUBMISSIONS_STORAGE=supabase

# Supabase Dashboard > Project Settings > Data API / API Keys.
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# Optional legacy alias; prefer SUPABASE_SECRET_KEY for new projects.
# SUPABASE_SERVICE_ROLE_KEY=

# Optional best-effort Google Apps Script web-app mirror. Configure both or
# neither. Supabase remains authoritative if this endpoint is unavailable.
GOOGLE_SHEETS_WEBHOOK_URL=
GOOGLE_SHEETS_WEBHOOK_SECRET=
