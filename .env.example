# Browser-safe Supabase configuration used by the static GitHub Pages build.
# Use the publishable key here; never put a secret or service-role key in a
# NEXT_PUBLIC_ variable.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Public canonical URL used for metadata. GitHub Pages sets the repository path
# during deployment; keep the local base path empty for development.
NEXT_PUBLIC_SITE_URL=https://abg-groupit.github.io/birla-opus-plant-workshop/
NEXT_PUBLIC_BASE_PATH=
