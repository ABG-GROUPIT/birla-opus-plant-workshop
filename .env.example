# Default: use Supabase when both credentials are set, otherwise keep the D1
# local/demo fallback. Set explicitly to `supabase` in production to fail fast
# if a secret is missing. Valid values: auto, d1, supabase.
SUBMISSIONS_STORAGE=auto

# Supabase Dashboard > Project Settings > Data API / API Keys.
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# Optional legacy alias; prefer SUPABASE_SECRET_KEY for new projects.
# SUPABASE_SERVICE_ROLE_KEY=

# Optional best-effort Google Apps Script web-app mirror. Configure both or
# neither. Supabase/D1 remains authoritative if this endpoint is unavailable.
GOOGLE_SHEETS_WEBHOOK_URL=
GOOGLE_SHEETS_WEBHOOK_SECRET=

